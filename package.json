{
  "name": "companion-module-pltech-kumatimer",
  "version": "2.1.2",
  "description": "Bitfocus Companion module for KUMA Timer (HTTP/JSON)",
  "type": "module",
  "main": "dist/main.js",
  "license": "MIT",
  "packageManager": "yarn@4.9.1",
  "engines": {
    "node": "^22.20",
    "yarn": "^4"
  },
  "scripts": {
    "postinstall": "husky",
    "build": "rimraf dist && yarn build:main",
    "build:main": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "dev": "yarn build && node scripts/fix-manifest.mjs && rsync -a --delete --exclude='tests/' --exclude='.git/' --exclude='*.tgz' --exclude='eslint.config.mjs' --exclude='vitest.config.ts' --exclude='tsconfig.eslint.json' --exclude='MIGRATION_NOTES.md' ./ $HOME/companion-dev/pltech-kumatimer/",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:raw": "eslint",
    "lint": "yarn lint:raw .",
    "lint:fix": "yarn lint:raw . --fix",
    "package": "yarn build && companion-module-build && node scripts/fix-manifest.mjs",
    "format": "prettier -w ."
  },
  "prettier": "@companion-module/tools/.prettierrc.json",
  "lint-staged": {
    "*.{css,json,md,scss}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "yarn lint:raw --fix"
    ]
  },
  "resolutions": {
    "brace-expansion@^5.0.5": "^5.0.6",
    "esbuild": "^0.28.1"
  },
  "dependencies": {
    "@companion-module/base": "^2.0.4"
  },
  "devDependencies": {
    "@companion-module/tools": "^3.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.6"
  }
}
